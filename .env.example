# Junto Environment Variables
# Copy to .env.local in the locations described below.

# === Backend (packages/backend/.env.local) ===
# Used by `npx convex dev`
CONVEX_DEPLOYMENT=dev:your-deployment-id

# === Web + Dashboard (apps/web/.env.local + apps/dashboard/.env.local) ===
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# === Web only (apps/web/.env.local) ===
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key

# === iOS ===
# Configured in Xcode scheme environment variables
# CONVEX_URL and CLERK_PUBLISHABLE_KEY
